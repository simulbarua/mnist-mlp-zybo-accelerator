# Normalize line endings on checkout
* text=auto

# Source files — LF everywhere
*.v    text eol=lf
*.vh   text eol=lf
*.xdc  text eol=lf
*.tcl  text eol=lf
*.py   text eol=lf
*.c    text eol=lf
*.h    text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.coe  text eol=lf
*.xci  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.cmake text eol=lf
*.ld   text eol=lf
*.tex  text eol=lf
*.xdc  text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.pdf   binary
*.docx  binary
*.elf   binary
*.bit   binary
*.bin   binary
*.dcp   binary
*.idx   binary
